    {
      "name": "03 Codigos HTTP autenticados",
      "item": [
        {
          "name": "200 OK - Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Login aceptado o MFA solicitado', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status_code).to.eql(200);",
                  "    pm.expect(json).to.have.property('success');",
                  "    if (json.mfa_required) {",
                  "        console.warn('MFA requerido: valida el codigo recibido antes de ejecutar endpoints admin.');",
                  "    } else {",
                  "        pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "        pm.expect(json.token_type).to.eql('Bearer');",
                  "        pm.environment.set('jwt_token', json.access_token);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
