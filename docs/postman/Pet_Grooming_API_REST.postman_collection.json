      "item": [
        {
          "name": "Obtener CSRF token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Guarda csrf_token', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.status_code).to.eql(200);",
                  "    pm.expect(json.data.csrf_token).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('csrf_token', json.data.csrf_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/csrf-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "csrf-token"
              ]
            }
          },
          "response": []
        }
      ]
